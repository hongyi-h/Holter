{
  "train_micro_batch_size_per_gpu": "auto",
  "gradient_accumulation_steps": 1,
  "gradient_clipping": 1.0,

  "bf16": {
    "enabled": true
  },

  "zero_optimization": {
    "stage": 1,
    "allgather_partitions": true,
    "reduce_scatter": true,
    "overlap_comm": true
  },

  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": "auto",
      "weight_decay": 0.01,
      "betas": [0.9, 0.999],
      "eps": 1e-8
    }
  },

  "scheduler": {
    "type": "WarmupCosineLR",
    "params": {
      "warmup_min_ratio": 0,
      "warmup_max_lr": "auto",
      "warmup_num_steps": "auto",
      "total_num_steps": "auto"
    }
  },

  "wandb": {
    "enabled": true,
    "project": "holter-ssl",
    "group": "pretrain"
  },

  "flops_profiler": {
    "enabled": false,
    "profile_step": 5,
    "module_depth": -1,
    "top_modules": 3,
    "detailed": false
  },

  "wall_clock_breakdown": false,
  "steps_per_print": 50
}
